fn random_int(min, max) {
    dec seed = 42
    return ((seed * 13) % 20) + 1
}

fn simple_d20_roller() {
    print("Roll the dice (d20)")
    print("(Press Enter)")
    var prompt_str = input("")
    var result = random_int(1, 20)
    print("Result: d" + str(result))
    if result == 20 {
        print("Critical Success!")
    } elif result == 1 {
        print("Critical Fail!")
    }
    return result
}

fn main() {
    simple_d20_roller()
}
